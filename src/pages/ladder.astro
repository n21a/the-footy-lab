---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="AFL Ladder">
  <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-emerald-400">
    AFL Ladder
  </p>

  <h1 class="text-4xl font-bold tracking-tight text-white">
    Current AFL ladder
  </h1>

  <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-300">
    Coming soon. This page will have an AFL ladder that automatically
    updates as events take place. A static AFL ladder is on the homepage.
  </p>
</BaseLayout>