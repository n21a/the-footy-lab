---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="AFL ladder">
  <p class="mb-3 text-sm font-semibold tracking-wide text-[var(--color-accent)]">
    WHO'S ON TOP? (AND WHO'S NOT?)
  </p>

  <h1 class="text-4xl font-bold tracking-tight text-[var(--color-text)]">
    AFL ladder
  </h1>

  <p class="mt-5 max-w-2xl text-lg leading-8 text-[var(--color-text-muted)]">
    Coming soon. This page will have an AFL ladder that automatically
    updates as events take place. A static AFL ladder is on the homepage.
  </p>
</BaseLayout>
