---

<BaseLayout
  title="Home"
  description="the-footy-lab is a beginner-friendly AFL guide."
>
  <section class="grid gap-8 lg:grid-cols-[1fr_0.95fr]">
    <div>
      <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-emerald-400">
        Aussie rules, made easier to follow
      </p>

      <h1 class="max-w-3xl text-4xl font-bold tracking-tight text-white sm:text-5xl">
        AFL rules, stats and terminology explained clearly.
      </h1>

      <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-300">
        <strong class="font-semibold text-white">the-footy-lab</strong> is a
        beginner-friendly AFL guide. It makes AFL rules, terminology and statistics
        more open, accessible and easy-to-digest for new fans and existing supporters.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/rules"
          class="rounded-xl bg-emerald-400 px-5 py-3 text-sm font-semibold text-slate-950 hover:bg-emerald-300"
        >
          Learn the rules
        </a>

        <a
          href="/ladder"
          class="rounded-xl border border-slate-700 px-5 py-3 text-sm font-semibold text-slate-100 hover:border-slate-500"
        >
          View ladder
        </a>
      </div>
    </div>

    <aside class="rounded-2xl border border-slate-800 bg-slate-900 p-5">
      <div class="mb-4 flex items-end justify-between gap-4">
        <div>
          <h2 class="text-lg font-semibold text-white">Current AFL ladder</h2>
          <p class="mt-1 text-xs text-slate-400"><b>Last updated:<b/> 2026-05-24 (post-Round 11)</p>
        </div>

        <a href="/ladder" class="text-xs font-semibold text-emerald-400 hover:text-emerald-300">
          Full ladder
        </a>
      </div>

      <div class="max-h-[430px] overflow-y-auto">
        <table class="w-full text-left text-xs">
          <thead class="sticky top-0 bg-slate-900 text-slate-400">
            <tr class="border-b border-slate-800">
              <th class="py-2 pr-2 font-medium">#</th>
              <th class="py-2 pr-2 font-medium">Team</th>
              <th class="py-2 pr-2 text-right font-medium">W-L-D</th>
              <th class="py-2 pr-2 text-right font-medium">%</th>
              <th class="py-2 text-right font-medium">Pts</th>
            </tr>
          </thead>

          <tbody>
            {
              ladder.map((team) => (
                <tr class="border-b border-slate-800/70">
                  <td class="py-2 pr-2 text-slate-400">{team.pos}</td>

                  <td class="py-2 pr-2">
                    <div class="flex items-center gap-2">
                      <img
                        src={team.logo}
                        alt={`${team.team} logo`}
                        class="h-5 w-5 shrink-0 object-contain"
                      />
                      <span class="font-medium text-slate-100">{team.team}</span>
                    </div>
                  </td>

                  <td class="py-2 pr-2 text-right text-slate-300">
                    {team.wins}-{team.losses}-{team.draws}
                  </td>

                  <td class="py-2 pr-2 text-right text-slate-300">
                    {team.percentage}
                  </td>

                  <td class="py-2 text-right font-semibold text-white">
                    {team.points}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </aside>
  </section>

  <section
    id="changelog"
    class="mt-14 rounded-2xl border border-slate-800 bg-slate-900 p-6"
  >
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-emerald-400">
          Changelog
        </p>

        <h2 class="text-2xl font-bold tracking-tight text-white">
          What's new in v0.1?
        </h2>
      </div>

      <a
        href="#changelog"
        class="w-fit rounded-xl border border-slate-700 px-4 py-2 text-sm font-semibold text-slate-100 hover:border-slate-500"
      >
        View changelog
      </a>
    </div>

    <ul class="mt-5 grid gap-3 text-sm leading-6 text-slate-300 sm:grid-cols-2 lg:grid-cols-3">
      <li>Static Astro foundation website</li>
      <li>Clear homepage and website navigation</li>
      <li>Static AFL ladder (updated after each round)</li>
    </ul>
  </section>
</BaseLayout>