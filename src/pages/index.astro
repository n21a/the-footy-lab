---
import BaseLayout from "../layouts/BaseLayout.astro";
import ladder from "../data/manual/260524-afl-ladder-round-11.json";
---

<BaseLayout
  title="Home"
  description="the-footy-lab is a beginner-friendly AFL guide."
>
  <section class="grid gap-8 lg:grid-cols-[1fr_0.95fr]">
    <div>
      <p class="mb-3 text-sm font-semibold tracking-wide text-[var(--color-accent)]">
        AUSSIE RULES, MADE SIMPLE
      </p>

      <h1 class="max-w-3xl text-4xl font-bold tracking-tight text-[var(--color-text)] sm:text-5xl">
        AFL rules, stats and terminology explained clearly.
      </h1>

      <p class="mt-5 max-w-2xl text-lg leading-8 text-[var(--color-text-muted)]">
        <strong class="font-semibold text-[var(--color-text)]">the-footy-lab</strong> is a
        beginner-friendly AFL guide. It makes AFL rules, terminology and statistics
        more open, accessible and easy-to-digest for new fans and existing supporters.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/rules"
          class="rounded-xl bg-[var(--color-accent)] px-5 py-3 text-sm font-semibold text-[var(--color-accent-contrast)] hover:opacity-90"
        >
          Learn the rules
        </a>

        <a
          href="/ladder"
          class="rounded-xl border border-[var(--color-border)] px-5 py-3 text-sm font-semibold text-[var(--color-text)] hover:bg-[var(--color-surface-muted)]"
        >
          View ladder
        </a>
      </div>
    </div>

    <aside class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5">
      <div class="mb-4 flex items-end justify-between gap-4">
        <div>
          <h2 class="text-lg font-semibold text-[var(--color-text)]">Current AFL ladder</h2>
          <p class="mt-1 text-xs text-[var(--color-text-muted)]"><b>Last updated:</b> 2026-05-24 (post-round 11)</p>
        </div>

        <a href="/ladder" class="text-xs font-semibold text-[var(--color-accent)] hover:opacity-80">
          Full ladder
        </a>
      </div>

      <div class="relative">
        <div class="scrollbar-hidden max-h-[430px] overflow-y-auto">
          <table class="w-full text-left text-xs">
            <thead class="sticky top-0 bg-[var(--color-surface)] text-[var(--color-text-muted)]">
              <tr class="border-b border-[var(--color-border)]">
                <th class="py-2 pr-2 text-center font-medium">#</th>
                <th class="py-2 pr-2 text-left font-medium">Team</th>
                <th class="py-2 pr-2 text-center font-medium">W-L-D</th>
                <th class="py-2 pr-2 text-center font-medium">%</th>
                <th class="hidden py-2 pr-2 text-center font-medium sm:table-cell">Form</th>
                <th class="py-2 text-center font-medium">Pts</th>
              </tr>
            </thead>

            <tbody>
              {
                ladder.map((team) => (
                  <tr class="border-b border-[var(--color-border)]">
                    <td class="py-2 pr-2 text-center text-[var(--color-text-muted)]">{team.position}</td>

                    <td class="py-2 pr-2">
                      <div class="flex items-center gap-2">
                        <img
                          src={team.logo}
                          alt={`${team.team} logo`}
                          class="h-5 w-5 shrink-0 object-contain"
                        />
                        <span class="font-medium text-left text-[var(--color-text)]">{team.team}</span>
                      </div>
                    </td>

                    <td class="py-2 pr-2 text-center text-[var(--color-text-muted)]">
                      {team.wins}-{team.losses}-{team.draws}
                    </td>

                    <td class="py-2 pr-2 text-center text-[var(--color-text-muted)]">
                      {team.percentage}
                    </td>

                    <td class="hidden py-2 pr-2 text-center sm:table-cell">
                      <div class="flex justify-end gap-1">
                        {
                          team.form.slice(-5).map((result) => (
                            <span
                              class:list={[
                                "flex h-5 w-5 items-center justify-center rounded-full text-[10px] font-bold text-white",
                                result === "W" && "bg-green-600",
                                result === "L" && "bg-red-600",
                                result === "D" && "bg-amber-500",
                              ]}
                              title={result === "W" ? "Win" : result === "L" ? "Loss" : "Draw"}
                              aria-label={result === "W" ? "Win" : result === "L" ? "Loss" : "Draw"}
                            >
                              {result}
                            </span>
                          ))
                        }
                      </div>
                    </td>

                    <td class="py-2 text-center font-semibold text-[var(--color-text)]">
                      {team.premiershipPoints}
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <div class="pointer-events none absolute bottom-0 left-0 right-0 h-12 bg-gradient-to-t from-[var(--color-surface)] to-transparent"></div>
      </div>
    </aside>
  </section>

  <section
    id="changelog"
    class="mt-14 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6"
  >
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="mb-2 text-sm font-semibold tracking-wide text-[var(--color-accent)]">
          Changelog
        </p>

        <h2 class="text-2xl font-bold tracking-tight text-[var(--color-text)]">
          What's new in v0.1?
        </h2>
      </div>

      <a
        href="#changelog"
        class="w-fit rounded-xl border border-[var(--color-border)] px-4 py-2 text-sm font-semibold text-[var(--color-text)] hover:bg-[var(--color-surface-muted)]"
      >
        View changelog
      </a>
    </div>

    <ul class="mt-5 grid gap-3 text-sm leading-6 text-[var(--color-text-muted)] sm:grid-cols-2 lg:grid-cols-3">
      <li>Static Astro foundation website</li>
      <li>Clear homepage and website navigation</li>
      <li>Static AFL ladder (updated after each round)</li>
    </ul>
  </section>
</BaseLayout>
