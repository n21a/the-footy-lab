---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Stats"
  description="AFL stats dashboards and explainers."
>
  <section>
    <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-emerald-400">
      Stats
    </p>

    <h1 class="text-4xl font-bold tracking-tight text-white">
      AFL Stats
    </h1>

    <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-300">
      Coming  soon. This section will contain ladder, fixtures, results, team profiles and
      simple statistical summaries - all made easier to understand.
    </p>
  </section>
</BaseLayout>