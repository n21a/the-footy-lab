---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="AFL glossary">
  <p class="mb-3 text-sm font-semibold tracking-wide text-[var(--color-accent)]">
    AFL IN SIMPLE TERMS
  </p>

  <h1 class="text-4xl font-bold tracking-tight text-[var(--color-text)]">
    AFL glossary
  </h1>

  <p class="mt-5 max-w-2xl text-lg leading-8 text-[var(--color-text-muted)]">
    Coming soon. This page will define common AFL terms such as disposals, marks, inside 50s,
    clearances, behinds, set shots, free kicks and holding the ball.
  </p>
</BaseLayout>
