---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="AFL rules">
  <p class="mb-3 text-sm font-semibold tracking-wide text-[var(--color-accent)]">
    THE RULES OF THE GAME, EXPLAINED
  </p>

  <h1 class="text-4xl font-bold tracking-tight text-[var(--color-text)]">
    AFL rules
  </h1>

  <p class="mt-5 max-w-2xl text-lg leading-8 text-[var(--color-text-muted)]">
    Coming soon. This section will explain scoring, marks, tackles, disposals, positions,
    common umpiring calls and the basic flow of an AFL match.
  </p>
</BaseLayout>
