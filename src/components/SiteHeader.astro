---
import ThemeToggle from "./ThemeToggle.astro";

const navItems = [
  { href: "/", label: "Home" },
  { href: "/ladder", label: "Ladder" },
  { href: "/rules", label: "Rules" },
  { href: "/glossary", label: "Glossary" },
  { href: "/stats", label: "Stats" },
];
---

<header class="border-b border-[var(--color-border)] bg-[var(--color-surface)]">
  <nav class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-5 sm:flex-row sm:items-center sm:justify-between">
    <a href="/" class="text-lg font-bold tracking-tight text-[var(--color-text)]">
      the-footy-lab
    </a>

    <div class="flex flex-wrap items-center gap-4 text-sm text-[var(--color-text-muted)]">
      {
        navItems.map((item) => (
          <a class="font-medium hover:text-[var(--color-text)]" href={item.href}>
            {item.label}
          </a>
        ))
      }

      <ThemeToggle />
    </div>
  </nav>
</header>
