---
const navItems = [
  { href: "/", label: "Home" },
  { href: "/ladder", label: "AFL Ladder" },
  { href: "/rules", label: "AFL Rules" },
  { href: "/glossary", label: "AFL Glossary" },
  { href: "/stats", label: "AFL Stats" },
];
---

<header class="border-b border-slate-800 bg-slate-950/90">
  <nav class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-5 sm:flex-row sm:items-center sm:justify-between">
    <a href="/" class="text-lg font-bold tracking-tight text-white">
      the-footy-lab
    </a>

    <div class="flex flex-wrap gap-3 text-sm text-slate-300">
      {
        navItems.map((item) => (
          <a class="hover:text-white" href={item.href}>
            {item.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>